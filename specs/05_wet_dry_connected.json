{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "background": null,
  "autosize": { "type": "fit", "contains": "padding" },
  "config": {
    "view": { "stroke": null },
    "axis": {
      "domain": false,
      "tickColor": "#c7d4d2",
      "gridColor": "#dbe5e3",
      "labelColor": "#294246",
      "titleColor": "#294246",
      "labelFont": "Trebuchet MS",
      "titleFont": "Trebuchet MS",
      "labelFontSize": 11,
      "titleFontSize": 12,
      "titleFontWeight": 700
    },
    "header": {
      "labelColor": "#294246",
      "titleColor": "#294246",
      "labelFont": "Trebuchet MS",
      "titleFont": "Trebuchet MS",
      "labelFontSize": 12,
      "titleFontSize": 12
    }
  },
  "data": { "url": "./data/aims_samples_2024_2025.csv" },
  "transform": [
    {
      "fold": [
        "dissolvedInorganicNitrogen",
        "chlorophyllA",
        "salinity",
        "suspendedSolids"
      ],
      "as": ["metric", "value"]
    },
    { "filter": "isValid(datum.value)" },
    {
      "calculate": "datum.metric === 'dissolvedInorganicNitrogen' ? 'DIN' : datum.metric === 'chlorophyllA' ? 'Chl-a' : datum.metric === 'salinity' ? 'Salinity' : 'SS'",
      "as": "metricLabel"
    },
    {
      "calculate": "datum.metric === 'dissolvedInorganicNitrogen' ? 1 : datum.metric === 'chlorophyllA' ? 2 : datum.metric === 'salinity' ? 3 : 4",
      "as": "metricOrder"
    },
    {
      "aggregate": [{ "op": "median", "field": "value", "as": "medianValue" }],
      "groupby": ["season", "metricLabel", "metricOrder"]
    }
  ],
  "facet": {
    "column": {
      "field": "metricLabel",
      "sort": { "field": "metricOrder", "order": "ascending" },
      "title": null,
      "header": { "labelFontWeight": 700, "labelOrient": "bottom", "labelPadding": 10 }
    }
  },
  "resolve": {
    "scale": {
      "x": "independent"
    }
  },
  "spec": {
    "width": 82,
    "height": 90,
    "layer": [
      {
        "mark": {
          "type": "line",
          "strokeWidth": 2.8,
          "color": "#8b9f56",
          "point": false
        },
        "encoding": {
          "x": {
            "field": "medianValue",
            "type": "quantitative",
            "axis": { "title": null, "tickCount": 4 }
          },
          "y": {
            "field": "season",
            "type": "ordinal",
            "sort": ["Wet season", "Dry season"],
            "title": null
          },
          "detail": { "field": "metricLabel" }
        }
      },
      {
        "mark": {
          "type": "point",
          "filled": true,
          "size": 120,
          "stroke": "#fffaf2",
          "strokeWidth": 1.4
        },
        "encoding": {
          "x": { "field": "medianValue", "type": "quantitative" },
          "y": {
            "field": "season",
            "type": "ordinal",
            "sort": ["Wet season", "Dry season"],
            "title": null
          },
          "color": {
            "field": "season",
            "type": "nominal",
            "scale": {
              "domain": ["Wet season", "Dry season"],
              "range": ["#0f5d66", "#c97b54"]
            },
            "legend": null
          },
          "tooltip": [
            { "field": "metricLabel", "title": "Metric" },
            { "field": "season", "title": "Season" },
            { "field": "medianValue", "title": "Median", "format": ".3f" }
          ]
        }
      },
      {
        "mark": {
          "type": "text",
          "align": "left",
          "dx": 8,
          "baseline": "middle",
          "font": "Trebuchet MS",
          "fontSize": 10,
          "color": "#294246"
        },
        "encoding": {
          "x": { "field": "medianValue", "type": "quantitative" },
          "y": {
            "field": "season",
            "type": "ordinal",
            "sort": ["Wet season", "Dry season"]
          },
          "text": { "field": "medianValue", "format": ".2f" }
        }
      }
    ]
  }
}
