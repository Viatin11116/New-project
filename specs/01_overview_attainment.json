{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "background": null,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "domain": false,
      "tickColor": "#9db3bb",
      "gridColor": "#d7e0e3",
      "labelColor": "#23404a",
      "titleColor": "#23404a",
      "labelFont": "Public Sans",
      "titleFont": "Public Sans",
      "labelFontSize": 12,
      "titleFontSize": 13,
      "titleFontWeight": 600
    },
    "legend": {
      "labelColor": "#23404a",
      "titleColor": "#23404a",
      "labelFont": "Public Sans",
      "titleFont": "Public Sans",
      "labelFontSize": 12,
      "titleFontSize": 13
    },
    "header": {
      "labelColor": "#23404a",
      "titleColor": "#23404a",
      "labelFont": "Public Sans",
      "titleFont": "Public Sans"
    },
    "style": {
      "guide-label": {
        "font": "Public Sans"
      },
      "guide-title": {
        "font": "Public Sans"
      }
    }
  },
  "width": "container",
  "height": 260,
  "data": {
    "url": "./data/reportcard_targets_2021_2022.csv"
  },
  "transform": [
    {
      "filter": "datum.regionCode === 'GBR'"
    },
    {
      "calculate": "datum.targetMode === 'protect' ? (datum.latestValue / datum.targetValue) * 100 : (datum.overallProgress / datum.targetValue) * 100",
      "as": "attainmentPct"
    },
    {
      "calculate": "datum.targetMode === 'protect' ? format(datum.latestValue, '.0f') + '%' : format(datum.overallProgress, '.1f') + '%'",
      "as": "displayLabel"
    }
  ],
  "layer": [
    {
      "data": {
        "values": [
          {
            "target": 100
          }
        ]
      },
      "mark": {
        "type": "rule",
        "strokeDash": [
          6,
          4
        ],
        "color": "#35546a",
        "opacity": 0.65
      },
      "encoding": {
        "x": {
          "field": "target",
          "type": "quantitative"
        }
      }
    },
    {
      "mark": {
        "type": "bar",
        "cornerRadiusEnd": 12,
        "height": 28
      },
      "encoding": {
        "y": {
          "field": "shortLabel",
          "type": "ordinal",
          "sort": {
            "field": "measureOrder",
            "order": "ascending"
          },
          "title": null
        },
        "x": {
          "field": "attainmentPct",
          "type": "quantitative",
          "scale": {
            "domain": [
              0,
              125
            ]
          },
          "axis": {
            "title": "Share of the 2025 target already achieved (%)",
            "tickCount": 6
          }
        },
        "color": {
          "field": "gradeRank",
          "type": "quantitative",
          "scale": {
            "domain": [
              0,
              1,
              2,
              3,
              4,
              5
            ],
            "range": [
              "#d7d6d2",
              "#a83f2f",
              "#d97736",
              "#e3bd61",
              "#5db39e",
              "#17756a"
            ]
          },
          "legend": null
        },
        "tooltip": [
          {
            "field": "measure",
            "title": "Measure"
          },
          {
            "field": "gradeLabel",
            "title": "Grade"
          },
          {
            "field": "overallProgress",
            "title": "Progress to date",
            "format": ".1f"
          },
          {
            "field": "targetValue",
            "title": "2025 target",
            "format": ".1f"
          },
          {
            "field": "attainmentPct",
            "title": "Target achieved (%)",
            "format": ".1f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 8,
        "fontSize": 12,
        "color": "#23404a"
      },
      "encoding": {
        "y": {
          "field": "shortLabel",
          "type": "ordinal",
          "sort": {
            "field": "measureOrder",
            "order": "ascending"
          }
        },
        "x": {
          "field": "attainmentPct",
          "type": "quantitative"
        },
        "text": {
          "field": "displayLabel"
        }
      }
    }
  ]
}
