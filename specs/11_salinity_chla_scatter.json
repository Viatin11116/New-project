{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "background": null,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "domain": false,
      "tickColor": "#9db3bb",
      "gridColor": "#d7e0e3",
      "labelColor": "#23404a",
      "titleColor": "#23404a",
      "labelFont": "Public Sans",
      "titleFont": "Public Sans",
      "labelFontSize": 12,
      "titleFontSize": 13,
      "titleFontWeight": 600
    },
    "legend": {
      "labelColor": "#23404a",
      "titleColor": "#23404a",
      "labelFont": "Public Sans",
      "titleFont": "Public Sans",
      "labelFontSize": 12,
      "titleFontSize": 13
    },
    "header": {
      "labelColor": "#23404a",
      "titleColor": "#23404a",
      "labelFont": "Public Sans",
      "titleFont": "Public Sans"
    },
    "style": {
      "guide-label": {
        "font": "Public Sans"
      },
      "guide-title": {
        "font": "Public Sans"
      }
    }
  },
  "width": "container",
  "height": 320,
  "data": {
    "url": "./data/aims_samples_2024_2025.csv"
  },
  "transform": [
    {
      "filter": "isValid(datum.salinity) && isValid(datum.chlorophyllA)"
    }
  ],
  "mark": {
    "type": "point",
    "filled": true,
    "opacity": 0.45,
    "size": 26,
    "stroke": "#ffffff",
    "strokeWidth": 0.35
  },
  "encoding": {
    "x": {
      "field": "salinity",
      "type": "quantitative",
      "axis": {
        "title": "Salinity (PSU)"
      }
    },
    "y": {
      "field": "chlorophyllA",
      "type": "quantitative",
      "scale": {
        "type": "log"
      },
      "axis": {
        "title": "Chlorophyll a (ug/L)"
      }
    },
    "color": {
      "field": "season",
      "type": "nominal",
      "scale": {
        "domain": [
          "Wet season",
          "Dry season"
        ],
        "range": [
          "#b55c2d",
          "#0f6e79"
        ]
      },
      "legend": {
        "title": null
      }
    },
    "tooltip": [
      {
        "field": "locationName",
        "title": "Site"
      },
      {
        "field": "region",
        "title": "Region"
      },
      {
        "field": "season",
        "title": "Season"
      },
      {
        "field": "salinity",
        "title": "Salinity",
        "format": ".2f"
      },
      {
        "field": "chlorophyllA",
        "title": "Chlorophyll a",
        "format": ".2f"
      }
    ]
  }
}
