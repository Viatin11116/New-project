{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "background": null,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "domain": false,
      "tickColor": "#9db3bb",
      "gridColor": "#d7e0e3",
      "labelColor": "#23404a",
      "titleColor": "#23404a",
      "labelFont": "Public Sans",
      "titleFont": "Public Sans",
      "labelFontSize": 12,
      "titleFontSize": 13,
      "titleFontWeight": 600
    }
  },
  "data": {
    "url": "./data/aims_region_metrics.csv"
  },
  "transform": [
    {
      "filter": "datum.period === '2024-2025'"
    },
    {
      "calculate": "datum.region === 'Cape York region' ? 'Cape York' : datum.region === 'Wet Tropics region' ? 'Wet Tropics' : datum.region === 'Burdekin region' ? 'Burdekin' : datum.region === 'Mackay Whitsunday region' ? 'Mackay Whitsunday' : 'Fitzroy'",
      "as": "regionLabel"
    },
    {
      "calculate": "format(datum.wetSeasonMedianSS, '.2f') + ' mg/L'",
      "as": "valueLabel"
    },
    {
      "calculate": "'n=' + format(datum.sampleCount, ',')",
      "as": "countLabel"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "bar",
        "cornerRadiusEnd": 10
      },
      "encoding": {
        "y": {
          "field": "regionLabel",
          "type": "ordinal",
          "sort": "-x",
          "title": null,
          "axis": {
            "labelLimit": 150
          }
        },
        "x": {
          "field": "wetSeasonMedianSS",
          "type": "quantitative",
          "scale": {
            "domain": [
              0,
              3
            ]
          },
          "axis": {
            "title": "Wet-season median SS (mg/L)",
            "tickCount": 4
          }
        },
        "color": {
          "field": "wetSeasonMedianSS",
          "type": "quantitative",
          "scale": {
            "domain": [
              0.8,
              2.6
            ],
            "range": [
              "#e6c86b",
              "#c96a34"
            ]
          },
          "legend": null
        },
        "tooltip": [
          {
            "field": "region",
            "title": "Region"
          },
          {
            "field": "sampleCount",
            "title": "Regional samples",
            "format": ","
          },
          {
            "field": "wetSeasonMedianSS",
            "title": "Wet-season median SS",
            "format": ".2f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 8,
        "dy": -8,
        "fontSize": 11,
        "fontWeight": 700,
        "color": "#23404a"
      },
      "encoding": {
        "y": {
          "field": "regionLabel",
          "type": "ordinal",
          "sort": "-x"
        },
        "x": {
          "field": "wetSeasonMedianSS",
          "type": "quantitative"
        },
        "text": {
          "field": "valueLabel"
        }
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 8,
        "dy": 10,
        "fontSize": 10,
        "color": "#4c6670"
      },
      "encoding": {
        "y": {
          "field": "regionLabel",
          "type": "ordinal",
          "sort": "-x"
        },
        "x": {
          "field": "wetSeasonMedianSS",
          "type": "quantitative"
        },
        "text": {
          "field": "countLabel"
        }
      }
    }
  ]
}
