{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "background": null,
  "config": {
    "view": { "stroke": null },
    "axis": {
      "domain": false,
      "tickColor": "#c7d4d2",
      "gridColor": "#dbe5e3",
      "labelColor": "#294246",
      "titleColor": "#294246",
      "labelFont": "Trebuchet MS",
      "titleFont": "Trebuchet MS",
      "labelFontSize": 11,
      "titleFontSize": 12,
      "titleFontWeight": 700
    },
    "legend": {
      "labelColor": "#294246",
      "titleColor": "#294246",
      "labelFont": "Trebuchet MS",
      "titleFont": "Trebuchet MS",
      "labelFontSize": 11,
      "titleFontSize": 12
    }
  },
  "data": { "url": "./data/aims_samples_2024_2025.csv" },
  "transform": [
    {
      "filter": "isValid(datum.dissolvedInorganicNitrogen) && isValid(datum.chlorophyllA)"
    }
  ],
  "mark": { "type": "point", "filled": true, "opacity": 0.45, "size": 58 },
  "encoding": {
    "x": {
      "field": "dissolvedInorganicNitrogen",
      "type": "quantitative",
      "title": "Dissolved inorganic nitrogen (mg/L)"
    },
    "y": {
      "field": "chlorophyllA",
      "type": "quantitative",
      "title": "Chlorophyll a (ug/L)"
    },
    "color": {
      "field": "season",
      "type": "nominal",
      "scale": {
        "domain": ["Wet season", "Dry season"],
        "range": ["#0f5d66", "#c97b54"]
      },
      "legend": { "title": null }
    },
    "tooltip": [
      { "field": "date", "title": "Sample date" },
      { "field": "region", "title": "Region" },
      { "field": "locationName", "title": "Location" },
      { "field": "season", "title": "Season" },
      {
        "field": "dissolvedInorganicNitrogen",
        "title": "Dissolved inorganic nitrogen (mg/L)",
        "format": ".3f"
      },
      { "field": "chlorophyllA", "title": "Chlorophyll a (ug/L)", "format": ".3f" }
    ]
  }
}
