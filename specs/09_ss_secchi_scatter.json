{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "background": null,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "domain": false,
      "tickColor": "#9db3bb",
      "gridColor": "#d7e0e3",
      "labelColor": "#23404a",
      "titleColor": "#23404a",
      "labelFont": "Public Sans",
      "titleFont": "Public Sans",
      "labelFontSize": 12,
      "titleFontSize": 13,
      "titleFontWeight": 600
    },
    "legend": {
      "labelColor": "#23404a",
      "titleColor": "#23404a",
      "labelFont": "Public Sans",
      "titleFont": "Public Sans",
      "labelFontSize": 12,
      "titleFontSize": 13
    },
    "header": {
      "labelColor": "#23404a",
      "titleColor": "#23404a",
      "labelFont": "Public Sans",
      "titleFont": "Public Sans"
    },
    "style": {
      "guide-label": {
        "font": "Public Sans"
      },
      "guide-title": {
        "font": "Public Sans"
      }
    }
  },
  "width": "container",
  "height": 320,
  "layer": [
    {
      "data": {
        "url": "./data/aims_samples_2024_2025.csv"
      },
      "transform": [
        {
          "filter": "isValid(datum.suspendedSolids) && isValid(datum.secchiDepthM) && datum.suspendedSolids <= 100"
        }
      ],
      "mark": {
        "type": "point",
        "filled": true,
        "opacity": 0.48,
        "size": 34,
        "stroke": "#ffffff",
        "strokeWidth": 0.45
      },
      "encoding": {
        "x": {
          "field": "suspendedSolids",
          "type": "quantitative",
          "scale": {
            "domain": [
              0,
              100
            ]
          },
          "axis": {
            "title": "Suspended solids (mg/L)"
          }
        },
        "y": {
          "field": "secchiDepthM",
          "type": "quantitative",
          "scale": {
            "domainMin": 0
          },
          "axis": {
            "title": "Secchi depth (m)"
          }
        },
        "color": {
          "value": "#0f6e79"
        },
        "tooltip": [
          {
            "field": "locationName",
            "title": "Site"
          },
          {
            "field": "region",
            "title": "Region"
          },
          {
            "field": "suspendedSolids",
            "title": "Suspended solids",
            "format": ".2f"
          },
          {
            "field": "secchiDepthM",
            "title": "Secchi depth",
            "format": ".2f"
          }
        ]
      }
    }
  ]
}
